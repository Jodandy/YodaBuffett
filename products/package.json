{
  "name": "yodabuffett-products",
  "private": true,
  "scripts": {
    "dev:screener": "pnpm --filter yodabuffett-screener dev",
    "dev:research": "pnpm --filter yodabuffett-research dev",
    "dev:hub": "pnpm --filter yodabuffett-hub dev",
    "build:screener": "pnpm --filter yodabuffett-screener build",
    "build:research": "pnpm --filter yodabuffett-research build",
    "build:hub": "pnpm --filter yodabuffett-hub build",
    "build:packages": "pnpm --filter './packages/*' build",
    "build:all": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
